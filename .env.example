# ==========================================================
# OptiCore Environment Configuration
# ==========================================================

# ==============================
# Application
# ==============================

APP_NAME=OptiCore

APP_VERSION=1.0.0

APP_ENV=development

DEBUG=True

SECRET_KEY=replace_with_secure_secret_key

# ==============================
# PostgreSQL Database
# ==============================

DB_HOST=localhost

DB_PORT=5432

DB_NAME=opticore

DB_USER=postgres

DB_PASSWORD=your_password_here

DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/opticore

# ==============================
# Gemini API
# ==============================

GEMINI_API_KEY=your_gemini_api_key

# ==============================
# Email Notifications (Optional)
# ==============================

SMTP_SERVER=smtp.gmail.com

SMTP_PORT=587

SMTP_EMAIL=your_email@gmail.com

SMTP_PASSWORD=your_app_password

# ==============================
# Upload Limits
# ==============================

MAX_UPLOAD_SIZE=100

# MB

# ==============================
# Reports
# ==============================

REPORT_PATH=exports/

# ==============================
# Machine Learning
# ==============================

MODEL_PATH=ml_models/

# ==============================
# Logging
# ==============================

LOG_LEVEL=INFO

LOG_FILE=logs/opticore.log

# ==============================
# Cache
# ==============================

CACHE_TIMEOUT=300

# seconds

# ==============================
# Theme
# ==============================

THEME=dark

PRIMARY_COLOR=#3B82F6

SECONDARY_COLOR=#10B981

ACCENT_COLOR=#F59E0B

# ==============================
# Demo Mode
# ==============================

DEMO_MODE=True
